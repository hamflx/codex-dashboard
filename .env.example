# Required for real TTFT probes.
OPENAI_API_KEY=

# Set to the Codex-capable OpenAI model you want to monitor.
CODEX_MODEL=gpt-5-codex

# Vercel Cron sends Authorization: Bearer $CRON_SECRET when this env var exists.
CRON_SECRET=

# Redis-compatible REST storage. Vercel KV and Upstash Redis both expose these shapes.
# Use either the UPSTASH_* pair or the KV_* pair.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional: choose a subset of built-in region IDs.
# TTFT_REGION_IDS=hong-kong,taiwan,singapore,japan,united-states,germany
TTFT_REGION_IDS=

# Optional: HTTP(S) proxy endpoints per region.
# Clash export files often contain trojan/vmess nodes, which Vercel functions cannot use directly.
# Provide server-side HTTP proxy endpoints here instead.
# Example object:
# TTFT_PROXY_JSON={"hong-kong":"http://user:pass@hk-proxy.example.com:8080","japan":"http://user:pass@jp-proxy.example.com:8080"}
TTFT_PROXY_JSON=

# Optional per-region env names also work.
# TTFT_PROXY_HONG_KONG=http://user:pass@hk-proxy.example.com:8080
# TTFT_PROXY_UNITED_STATES=http://user:pass@us-proxy.example.com:8080

# Local/demo controls.
TTFT_USE_MOCK=1
TTFT_TIMEOUT_MS=15000
TTFT_PARALLELISM=8
